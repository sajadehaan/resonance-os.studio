---
import Base from '../layouts/Base.astro';
import MetaballButton from '../components/MetaballButton.astro';
---
<Base
  title="Resonance.SITE — A website rebuilt from your brand"
  description="A full Astro build on top of your Resonance.ID. Up to four pages or one strong single-page, two weeks from kickoff to live. From €3,500, ID credited in full."
  ctaLabel="Book a call"
  ctaHref="mailto:saja@resonance-os.studio?subject=Book%20a%20call%20about%20Resonance.SITE"
  ctaHeadlineA="Build with"
  ctaHeadlineB="Resonance.SITE."
  ctaSub="From €3,500. Two weeks from kickoff to live. Your Resonance.ID is the brief — built first and credited in full."
>

<!-- ── HERO ──────────────────────────────────────── -->
<section class="s-hero">
  <div class="hero-body">
    <p class="hero-eyebrow r">// RESONANCE.SITE — FROM €3,500</p>
    <h1 class="hero-h1 diag-h">
      <span class="diag-line">When something</span>
      <span class="diag-line">is changing,</span>
      <span class="diag-line">we build the site.</span>
    </h1>
    <p class="hero-sub r" data-d="1">The full Astro build on top of your ID. Up to four pages or one strong single-page. Two weeks from kickoff to live — built for the moment the old site has stopped matching who you are.</p>
    <div class="hero-ctas r" data-d="2">
      <MetaballButton href="mailto:saja@resonance-os.studio?subject=Book%20a%20call%20about%20Resonance.SITE" label="Book a call" />
      <MetaballButton href="/id" variant="ghost" label="Start with your ID" />
    </div>
    <p class="r" data-d="3" style="margin-top:1rem;font-size:0.8125rem;color:var(--ink-m)">Engagements are governed by our <a href="/terms" style="color:var(--accent)">Terms</a>.</p>
  </div>
</section>


<!-- ── LOGO SEPARATOR ────────────────────────────── -->
<div class="logo-sep" aria-hidden="true">
  <svg class="logo-sep-mark" viewBox="0 0 550 550" fill="none" xmlns="http://www.w3.org/2000/svg">
    <use href="#logo-mark"/>
  </svg>
</div>


<!-- ── WHAT IT IS ───────────────────────────────────── -->
<section class="s" id="overview">
  <span class="lbl r">// RESONANCE.SITE</span>
  <h2 class="h2 diag-h r" data-d="1">
    <span class="diag-line">Built from the brand,</span>
    <span class="diag-line">not a template.</span>
  </h2>

  <div class="prod-grid" style="margin-top:2.5rem">
    <div class="r" data-d="2">
      <p class="body" style="margin-bottom:1rem">Resonance.SITE is the full Astro + Sanity build, on top of your ID. Up to four pages or one strong single-page. Two weeks from kickoff to live.</p>
      <p class="body" style="margin-bottom:1rem">Built for the moment something is changing — a new location, a teacher training, a price step, an online program. Something where the existing website has stopped matching who you are.</p>
      <p class="body" style="margin-bottom:2rem">Your ID is always built first — not as a trial for the site, but as its briefing. If you bought your ID already, the €247 is credited in full. From €3,500.</p>
      <MetaballButton href="mailto:saja@resonance-os.studio?subject=Book%20a%20call%20about%20Resonance.SITE" label="Book a call" />
    </div>

    <div class="browser r" data-d="3">
      <div class="browser-bar">
        <div class="b-dot"></div><div class="b-dot"></div><div class="b-dot"></div>
        <div class="b-url">resonance-os.studio</div>
      </div>
      <div class="browser-body">
        <div class="b-nav">
          <span class="b-logo">Resonance.OS</span>
          <div class="b-links"><div class="b-link"></div><div class="b-link"></div><div class="b-link"></div></div>
        </div>
        <p class="b-h">Your brand, live<br>on every screen.</p>
        <div class="b-line"></div>
        <div class="b-line b-line--s"></div>
        <span class="b-cta">Get started →</span>
      </div>
    </div>
  </div>
</section>


<!-- ── HOW A BUILD GOES ─────────────────────────────── -->
<section class="s" id="process" style="background:var(--bg-alt)">
  <span class="lbl r">// HOW A BUILD GOES</span>
  <h2 class="h2 diag-h r" data-d="1">
    <span class="diag-line">Two weeks.</span>
    <span class="diag-line">Kickoff to live.</span>
  </h2>
  <div class="steps">
    <div class="step r" data-d="1">
      <span class="step-n">01</span>
      <p class="step-h">Kickoff from your ID.</p>
      <p class="step-p">We start from your Resonance.ID — the palette, the voice, the section blueprint are already decided. If you don't have one yet, it's built first and credited in full.</p>
    </div>
    <div class="step r" data-d="2">
      <span class="step-n">02</span>
      <p class="step-h">We build.</p>
      <p class="step-p">A full Astro build in your palette and type, following your blueprint. Up to four pages or one strong single-page. You see it on a staging link as it comes together.</p>
    </div>
    <div class="step r" data-d="3">
      <span class="step-n">03</span>
      <p class="step-h">You go live.</p>
      <p class="step-p">Deployed, fast, and yours. No template, no monthly platform fee, no builder lock-in. A site that finally matches the room you hold.</p>
    </div>
  </div>
</section>

</Base>
