<section class="s panel" id="testimonials" style="z-index:7; padding-bottom:0">
  <span class="lbl r">// TESTIMONIALS</span>
  <h2 class="h2 diag-h r" data-d="1">
    <span class="diag-line">What people said</span>
    <span class="diag-line">after their</span>
    <span class="diag-line">Resonance.ID landed.</span>
  </h2>
  <div class="conv-track-wrap">
    <div class="conv-track">
      <div class="conv-set">
