---
import MetaballButton from '../components/MetaballButton.astro';
import '../styles/global.css';
// Note: Lenis smooth-scroll init wired in the body <script> below via lib/scroll.ts

interface Props {
  title?: string;
  description?: string;
  ctaLabel?: string;
  ctaHref?: string;
  ctaHeadlineA?: string;
  ctaHeadlineB?: string;
  ctaSub?: string;
}

const {
  title = 'Resonance.OS — Brand Identity for Movement & Wellness',
  description = 'A brand identity studio for boutique movement and wellness operators. We close the gap between who you are when you teach and how you come across on a screen.',
  ctaLabel = 'Start your ID — €247',
  ctaHref = 'mailto:saja@resonance-os.studio?subject=Start%20my%20Resonance.ID',
  ctaHeadlineA = 'Start with',
  ctaHeadlineB = 'Resonance.ID.',
  ctaSub = '€247. About 20 minutes. Sent to your inbox the same day.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/Resonance.OS - logo n-background.svg" type="image/svg+xml" />
  <link rel="icon" href="/Resonance.OS - logo n-background@2x.png" type="image/png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Urbanist:wght@200;300;400;500;600;700&family=Geist+Mono:wght@400&display=swap" rel="stylesheet" />
  <script type="module" src="https://unpkg.com/@splinetool/viewer@1.9.48/build/spline-viewer.js"></script>
</head>

<body>

<!-- Reusable logo mark — referenced by all separators and footer icon -->
<svg width="0" height="0" style="position:absolute;overflow:hidden" aria-hidden="true">
  <defs>
    <symbol id="logo-mark" viewBox="0 0 550 550">
