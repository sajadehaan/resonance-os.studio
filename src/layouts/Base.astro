      <path d="M274.452 50.0306C282.73 49.1226 289.687 68.5189 289.99 93.3541C290.293 118.189 283.828 139.059 275.549 139.969C267.27 140.879 260.313 121.483 260.01 96.6459C259.707 71.8094 266.173 50.9386 274.452 50.0306Z" fill="#f75b1d"/>
      <path d="M274.452 410.031C282.73 409.123 289.687 428.519 289.99 453.354C290.293 478.189 283.828 499.059 275.549 499.969C267.27 500.879 260.313 481.483 260.01 456.646C259.707 431.809 266.173 410.939 274.452 410.031Z" fill="#f75b1d"/>
    </symbol>
  </defs>
</svg>

<!-- ── NAV ──────────────────────────────────────── -->
<nav class="nav">
  <a href="/" class="nav-logo">
    <svg class="nav-logo-mark" viewBox="0 0 550 550" fill="none" xmlns="http://www.w3.org/2000/svg">
      <use href="#logo-mark"/>
    </svg>
    Resonance.OS
  </a>
  <div class="nav-right">
    <div class="fl-menu" id="flMenu">
      <svg class="fl-balls" id="flBalls" xmlns="http://www.w3.org/2000/svg"></svg>
      <div class="fl-labels" id="flLabels"></div>
    </div>
    <MetaballButton href="#footer" label="Get in touch" />
  </div>
  <button class="nav-hamburger" id="navHamburger" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="navMenu">
    <span class="nav-hamburger-line" aria-hidden="true"></span>
    <span class="nav-hamburger-line" aria-hidden="true"></span>
    <span class="nav-hamburger-line" aria-hidden="true"></span>
  </button>
</nav>

<!-- ── MOBILE OVERLAY MENU ─────────────────────── -->
<div class="nav-overlay" id="navMenu" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Site menu">
  <div class="nav-overlay-top">
    <a href="/" class="nav-logo nav-logo--overlay">
      <svg class="nav-logo-mark" viewBox="0 0 550 550" fill="none" xmlns="http://www.w3.org/2000/svg">
        <use href="#logo-mark"/>
      </svg>
      Resonance.OS
    </a>
    <button class="nav-close" id="navClose" type="button" aria-label="Close menu">
      <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <path d="M1 1l12 12M13 1L1 13"/>
      </svg>
    </button>
  </div>
  <nav class="nav-overlay-links" aria-label="Mobile primary">
    <a href="/id"><span class="nav-overlay-n">01</span><span class="nav-overlay-lbl">Resonance.ID</span><span class="nav-overlay-arrow" aria-hidden="true">→</span></a>
    <a href="/site"><span class="nav-overlay-n">02</span><span class="nav-overlay-lbl">Resonance.SITE</span><span class="nav-overlay-arrow" aria-hidden="true">→</span></a>
    <a href="/#projects"><span class="nav-overlay-n">03</span><span class="nav-overlay-lbl">Projects</span><span class="nav-overlay-arrow" aria-hidden="true">→</span></a>
    <a href="/#studio"><span class="nav-overlay-n">04</span><span class="nav-overlay-lbl">The studio</span><span class="nav-overlay-arrow" aria-hidden="true">→</span></a>
  </nav>
  <div class="nav-overlay-foot">
    <a href="mailto:saja@resonance-os.studio">saja@resonance-os.studio</a>
    <span>Leeuwarden &amp; Berlin</span>
  </div>
</div>

<slot />

<!-- ── FOOTER ──────────────────────────────────────── -->
<section class="s-footer panel panel--dark" id="footer" style="z-index:8">
  <div class="footer-cta">
    <h2 class="footer-big diag-h">
      <span class="diag-line">{ctaHeadlineA}</span>
      <span class="diag-line">{ctaHeadlineB}</span>
    </h2>
    <p class="footer-sub">{ctaSub}</p>
    <div class="footer-btns">
      <MetaballButton href={ctaHref} label={ctaLabel} />
      <MetaballButton href="mailto:saja@resonance-os.studio" variant="ghost" icon="mail" label="Or write — saja@resonance-os.studio" />
    </div>
  </div>

  <div class="slash-sep" style="padding:0.5rem 0; margin-bottom:var(--vp)" aria-hidden="true">// </div>

  <div class="footer-bar">
    <div class="footer-brand">
      <svg width="20" height="20" viewBox="0 0 550 550" fill="none" style="flex-shrink:0">
        <use href="#logo-mark"/>
      </svg>
      <div class="footer-brand-text">
        <span class="footer-logo">Resonance.OS</span>
        <span class="footer-tag">Brand identity for movement &amp; wellness.</span>
      </div>
    </div>
    <nav class="footer-links">
      <a href="/id">Resonance.ID</a>
      <a href="/site">Resonance.SITE</a>
      <a href="/#studio">The studio</a>
    </nav>
    <div class="footer-right">
      <a href="mailto:saja@resonance-os.studio" class="footer-contact">saja@resonance-os.studio</a>
      <span class="footer-contact" style="cursor:default">Leeuwarden &amp; Berlin</span>
    </div>
  </div>

  <nav class="footer-legal" aria-label="Legal">
    <a href="/terms">Terms of Service</a>
    <a href="/refund-policy">Refund Policy</a>
  </nav>
</section>


<script>
  // Lenis smooth scroll — wired across every page through this layout
  import { initScroll } from '../lib/scroll';
  initScroll();

  // Scroll reveals
  const ro = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('v'); ro.unobserve(e.target); }
    }),
    { threshold: 0.08 }
  );
  document.querySelectorAll('.r').forEach(el => ro.observe(el));

  // Metaball nav
  (function(){
    var ITEMS = [
      { label: 'Resonance.ID',   href: '/id',        w: 150 },
      { label: 'Resonance.SITE', href: '/site',      w: 165 },
      { label: 'Projects',       href: '/#projects', w: 115 }
    ];
    var BASE_GAP   = 10;
    var ACTIVE_GAP = 30;
    var HEIGHT     = 40;
    var CORNER     = 12;
    var V          = 0.54;
    var HANDLE     = 2.4;
    var PILL_FILL  = '#222222';

    // Active item by current path — subpages light their own pill
    var path = location.pathname.replace(/\/$/, '');
    var ACTIVE = path === '/id' ? 0 : path === '/site' ? 1 : -1;

    // Hiroyuki Sato metaball algorithm (varun.ca/metaballs) — unchanged
    function dist(a,b){return Math.hypot(a[0]-b[0],a[1]-b[1]);}
    function ang(a,b){return Math.atan2(a[1]-b[1],a[0]-b[0]);}
    function vec(o,a,r){return [o[0]+Math.cos(a)*r,o[1]+Math.sin(a)*r];}
    function metaball(r1,r2,c1,c2,hs,v){
      var HP=Math.PI/2,d=dist(c1,c2),maxD=r1+r2*2.5,u1,u2;
      if(r1===0||r2===0||d>maxD||d<=Math.abs(r1-r2)) return '';
      if(d<r1+r2){
        u1=Math.acos((r1*r1+d*d-r2*r2)/(2*r1*d));
        u2=Math.acos((r2*r2+d*d-r1*r1)/(2*r2*d));
      } else { u1=0; u2=0; }
      var ac=ang(c2,c1),ms=Math.acos((r1-r2)/d);
      var a1=ac+u1+(ms-u1)*v,a2=ac-u1-(ms-u1)*v;
      var a3=ac+Math.PI-u2-(Math.PI-u2-ms)*v,a4=ac-Math.PI+u2+(Math.PI-u2-ms)*v;
      var p1=vec(c1,a1,r1),p2=vec(c1,a2,r1),p3=vec(c2,a3,r2),p4=vec(c2,a4,r2);
      var tr=r1+r2,d2b=Math.min(v*hs,dist(p1,p3)/tr),d2=d2b*Math.min(1,(d*2)/(r1+r2));
      var hr1=r1*d2,hr2=r2*d2;
      var h1=vec(p1,a1-HP,hr1),h2=vec(p2,a2+HP,hr1),h3=vec(p3,a3+HP,hr2),h4=vec(p4,a4-HP,hr2);
      var f=function(p){return p[0].toFixed(2)+','+p[1].toFixed(2);};
      return ['M',f(p1),'C',f(h1),f(h3),f(p3),'A',r2,r2,0,d>r1?1:0,0,f(p4),'C',f(h4),f(h2),f(p2)].join(' ');
    }

    var svg=document.getElementById('flBalls'),
        labels=document.getElementById('flLabels'),
        menu=document.getElementById('flMenu');
    if(!svg||!labels||!menu) return;
    var R=HEIGHT/2,PAD=R+4,cy;
    var curGaps=[],targetGaps=[];

    function computeTargets(){
      var t=[];
      for(var i=0;i<ITEMS.length-1;i++)
        t.push((i===ACTIVE-1||i===ACTIVE)?ACTIVE_GAP:BASE_GAP);
      return t;
    }

    function render(gaps){
      var x=PAD,rects=[];
      ITEMS.forEach(function(it){
        rects.push({x:x,w:it.w,it:it});
        x+=it.w+(gaps[rects.length-1]!==undefined?gaps[rects.length-1]:0);
      });
      var totalW=x+PAD,totalH=HEIGHT+PAD*2;
      cy=PAD+R;
      svg.setAttribute('width',totalW);svg.setAttribute('height',totalH);
      svg.setAttribute('viewBox','0 0 '+totalW+' '+totalH);
      menu.style.width=totalW+'px';menu.style.height=totalH+'px';

      var conn='';
      for(var i=0;i<rects.length-1;i++){
        var lc=[rects[i].x+rects[i].w-R,cy],rc=[rects[i+1].x+R,cy];
        var bp=metaball(R,R,lc,rc,HANDLE,V);
        if(bp) conn+='<path d="'+bp+'" fill="'+PILL_FILL+'"/>';
      }
      var caps='';
      rects.forEach(function(r){
        caps+='<rect x="'+r.x+'" y="'+PAD+'" width="'+r.w+'" height="'+HEIGHT+'" rx="'+CORNER+'" ry="'+CORNER+'" fill="'+PILL_FILL+'"/>';
      });
      svg.innerHTML=conn+caps;

      if(!labels.childElementCount){
        var html='';
        rects.forEach(function(r,i){
          html+='<a href="'+r.it.href+'" data-i="'+i+'" style="left:'+r.x+'px;width:'+r.w+'px;">'+r.it.label+'</a>';
        });
        labels.innerHTML=html;
      } else {
        labels.querySelectorAll('a').forEach(function(a,i){
          a.style.left=rects[i].x+'px';a.style.width=rects[i].w+'px';
        });
      }
    }

    function animate(){
      var moving=false;
      for(var i=0;i<curGaps.length;i++){
        var diff=targetGaps[i]-curGaps[i];
        if(Math.abs(diff)>0.3){curGaps[i]+=diff*0.18;moving=true;}
        else curGaps[i]=targetGaps[i];
      }
      render(curGaps);
      if(moving) requestAnimationFrame(animate);
    }

    for(var i=0;i<ITEMS.length-1;i++) curGaps.push(BASE_GAP);
    targetGaps=computeTargets();
    render(curGaps);
    requestAnimationFrame(animate);
  })();

  // Mobile hamburger menu — toggle overlay, scroll-lock, ESC close, link close
  (() => {
    const hamb  = document.getElementById('navHamburger');
    const menu  = document.getElementById('navMenu');
    const close = document.getElementById('navClose');
    if (!hamb || !menu || !close) return;
    let lastFocus: HTMLElement | null = null;
    const open = () => {
      lastFocus = document.activeElement as HTMLElement | null;
      menu.setAttribute('aria-hidden','false');
      hamb.setAttribute('aria-expanded','true');
      document.body.classList.add('is-menu-open');
      close.focus();
    };
    const shut = () => {
      menu.setAttribute('aria-hidden','true');
      hamb.setAttribute('aria-expanded','false');
      document.body.classList.remove('is-menu-open');
      if (lastFocus) lastFocus.focus();
    };
    hamb.addEventListener('click', open);
    close.addEventListener('click', shut);
    menu.querySelectorAll('a').forEach(a => a.addEventListener('click', shut));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.getAttribute('aria-hidden') === 'false') shut();
    });
  })();
</script>

</body>
</html>
